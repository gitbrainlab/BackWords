{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://backwords.app/schemas/AppSettings.schema.json",
  "title": "AppSettings",
  "description": "User-configurable application settings persisted in UserDefaults",
  "type": "object",
  "required": ["proxyBaseURL", "appearance", "defaultPerspective", "maxSources", "cachePolicy", "telemetryEnabled"],
  "properties": {
    "proxyBaseURL": {
      "type": "string",
      "format": "uri",
      "default": "http://localhost:8000",
      "description": "Base URL of the BackWords proxy server"
    },
    "appearance": {
      "type": "string",
      "enum": ["system", "light", "dark"],
      "default": "system",
      "description": "UI appearance mode"
    },
    "defaultPerspective": {
      "type": "string",
      "enum": ["scholarly", "modernPremium", "consumerFriendly"],
      "default": "modernPremium",
      "description": "Default color palette"
    },
    "maxSources": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10,
      "default": 3,
      "description": "Maximum number of sources to display per result"
    },
    "cachePolicy": {
      "type": "string",
      "enum": ["always", "networkFirst", "never"],
      "default": "networkFirst",
      "description": "How aggressively to cache API responses"
    },
    "telemetryEnabled": {
      "type": "boolean",
      "default": false,
      "description": "Whether to send anonymous usage telemetry"
    },
    "mockMode": {
      "type": "boolean",
      "default": false,
      "description": "Use MockAPIClient instead of live network calls"
    },
    "lastUpdated": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "ISO8601 timestamp of last settings save"
    }
  },
  "additionalProperties": false
}
